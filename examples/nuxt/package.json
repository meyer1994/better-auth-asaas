{
  "name": "better-auth-asaas-example-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "clean": "rm -rf node_modules .nuxt .output",
    "lint": "eslint .",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "auth:generate": "pnpx auth generate --yes --config server/utils/auth.ts --output server/db/auth.ts && pnpm exec eslint --fix server/db/auth.ts",
    "db:push": "pnpm exec drizzle-kit push",
    "db:generate": "pnpm run auth:generate && pnpm exec drizzle-kit generate",
    "db:migrate": "pnpm exec drizzle-kit migrate"
  },
  "dependencies": {
    "@better-auth/core": "catalog:",
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@iconify-json/lucide": "^1.2.118",
    "@iconify-json/simple-icons": "^1.2.91",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "^4.10.0",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@tanstack/table-core": "^8.21.3",
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "better-auth": "catalog:",
    "better-auth-asaas": "workspace:*",
    "better-sqlite3": "latest",
    "drizzle-orm": "latest",
    "nuxt": "^4.5.0",
    "tailwindcss": "^4.3.3",
    "vue": "^3.5.40",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@types/better-sqlite3": "latest",
    "drizzle-kit": "latest",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.7"
  }
}
