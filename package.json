{
  "name": "@meyer1994/better-auth-asaas",
  "version": "1.0.0",
  "description": "Asaas payments plugin for Better Auth",
  "author": "",
  "keywords": [
    "better-auth",
    "asaas",
    "payments",
    "pix",
    "subscriptions"
  ],
  "license": "ISC",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf node_modules dist .tsup",
    "test": "vitest run --reporter verbose"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./zods": {
      "types": "./dist/zods.d.ts",
      "default": "./dist/zods.js"
    }
  },
  "devDependencies": {
    "@better-auth/core": "catalog:",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.5",
    "better-auth": "catalog:",
    "better-call": "catalog:",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "better-auth": "^1.6.23",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
