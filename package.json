{
  "name": "better-auth-asaas",
  "version": "1.0.0",
  "description": "Asaas payments plugin for Better Auth",
  "author": "",
  "keywords": [
    "better-auth",
    "asaas",
    "payments",
    "pix",
    "subscriptions"
  ],
  "license": "ISC",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules dist .tsup",
    "test": "vitest run --reporter verbose"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "devDependencies": {
    "@better-auth/core": "catalog:",
    "@types/node": "^25.9.5",
    "better-auth": "catalog:",
    "better-call": "catalog:",
    "eslint": "^10.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@better-auth/core": "catalog:",
    "better-auth": "catalog:",
    "better-call": "catalog:",
    "zod": "catalog:"
  }
}