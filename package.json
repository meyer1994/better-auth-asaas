{
  "name": "better-auth-asaas-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm run lib dev",
    "test": "pnpm run lib test",
    "build": "pnpm run lib build",
    "lib": "pnpm --filter better-auth-asaas",
    "example:nuxt": "pnpm --filter better-auth-asaas-example-nuxt",
    "example:next": "pnpm --filter better-auth-asaas-example-next",
    "dev:nuxt": "pnpm run example:nuxt dev",
    "dev:next": "pnpm run example:next dev",
    "build:nuxt": "pnpm --filter better-auth-asaas-example-nuxt... build",
    "build:next": "pnpm --filter better-auth-asaas-example-next... build"
  },
  "devDependencies": {
    "@openai/codex": "^0.136.0",
    "@types/node": "^25.6.0",
    "better-auth": "^1.6.11",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5",
    "zod": "^4.4.3"
  }
}